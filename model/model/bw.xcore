@Ecore(nsURI="https://bw.tibco.models.nasdanika.org", nsPrefix="org.nasdanika.models.tibco.bw")
@GenModel(
    documentation="Xcore model for Tibco BusinessWorks 5.x process concepts.",
    bundleManifest="false",
    featureDelegation="Dynamic",
    complianceLevel="21.0",
    suppressGenModelAnnotations="false",
    copyrightFields="false",
    operationReflection="true",
    importOrganizing="true"
)
package org.nasdanika.models.tibco.bw

annotation "http://www.eclipse.org/emf/2002/Ecore" as Ecore
annotation "http://www.eclipse.org/emf/2002/GenModel" as GenModel

/**
 * Abstract base for process elements that are identified by name within a process.
 * Corresponds to the NamedType complex type in the BW process schema.
 */
abstract class NamedElement {

    /**
     * The element's unique name within its containing scope (process or group).
     * Used as the reference target in Transition.from and Transition.to.
     */
    id String name

    /**
     * Optional human-readable description of this element.
     */
    String description
}

abstract class Container extends NamedElement {

    /**
     * Activities (tasks/steps) at the top level of this process.
     */
    contains Activity[] activities keys name

    /**
     * Groups of activities at the top level of this process (loops, scope, etc.).
     */
    contains Group[] groups keys name

    /**
     * Transitions at the top level of this process.
     */
    contains Transition[] transitions
    
    /**
     * A synthetic node populated from startName, startType, startX, startY
     */
    refers Node start
    
    /**
     * A synthetic node populated from endName, endType, endX, endY
     */
    refers Node end
    
}

/**
 * Root element of a Tibco BW 5.x process file (.process).
 * Corresponds to pd:ProcessDefinition in the XML namespace
 * http://xmlns.tibco.com/bw/process/2003.
 */
class ProcessDefinition extends Container, CallTarget, Resource {

    /**
     * Canonical type of the start element (optional).
     */
    String startType

    /**
     * Canonical type of the end element (optional).
     */
    String endType

    /**
     * The XML target namespace declared in the process file.
     * Used to qualify XPath expressions within the process.
     */
    String targetNamespace

    /**
     * XSL bindings that produce the process return value (output schema).
     * Stored as raw XML text because the bindings reference arbitrary namespaces.
     */
    String returnBindings
    
    /**
     * The optional event-source activity that starts this process
     * (e.g. an HTTP receiver, JMS queue listener, Timer, ...).
     * When present, startName refers to this starter's name.
     */
    contains Starter starter

    /**
     * Visual annotation labels on the diagram.
     */
    contains Label[] labels

    /**
     * Process-scoped variables declared in the process.
     */
    contains ProcessVariable[] processVariables keys name

    /**
     * Error schemas that this process can throw.
     * Stored as raw XML text because they are arbitrary XSD fragments.
     */
    String errorSchemas
}


class Node extends NamedElement {

    /**
     * X coordinate on the design canvas.
     */
    int x

    /**
     * Y coordinate on the design canvas.
     */
    int y
    
    refers Transition[] outgoingTransitions opposite source
    
    refers Transition[] incomingTransitions opposite target
    
}

class TypedElement extends NamedElement {

    /**
     * Fully-qualified Java class name of the activity implementation,
     * e.g. "com.tibco.pe.core.WriteToLogActivity".
     */
    String ^type
    
}

class TypedNode extends TypedElement, Node {

    /**
     * Palette / resource-type identifier used by the BW Designer,
     * e.g. "ae.activities.log".
     */
    String resourceType
    
}

/**
 * An activity (task or step) within a BW process or group.
 * Corresponds to pd:activity in the process XML.
 */
class Activity extends TypedNode, Caller {

    /**
     * Activity-specific configuration, stored as raw XML text.
     * The structure varies per activity type.
     */
    String config

    /**
     * XSL input bindings for this activity, stored as raw XML text.
     */
    String inputBindings
    
    // TODO - input/output transitions, perhaps derived        
    
}

/**
 * An event-source (starter) activity that triggers the process.
 * Corresponds to pd:starter in the process XML.
 * Examples: HTTP Event Source, JMS Queue Receiver, Timer, File Poller.
 *
 * Structurally identical to a regular Activity; modelled as a distinct
 * class so that tooling can easily distinguish starters from regular steps.
 */
class Starter extends Activity {
    
}

/**
 * A group of activities, used to model structured constructs such as:
 *   - Loops (Repeat-Until, For-Each, While)
 *   - Error handlers / Fault handlers
 *   - Critical sections
 *   - Scope groups
 *
 * Corresponds to pd:group in the process XML.
 */
class Group extends Activity, Container {

    /**
     * Width of the expanded group frame on the design canvas.
     */
    int width

    /**
     * Height of the expanded group frame on the design canvas.
     */
    int height

    /**
     * Width of the group icon when collapsed.
     */
    int collapsedWidth

    /**
     * Height of the group icon when collapsed.
     */
    int collapsedHeight

    /**
     * Whether the group is shown in expanded form on the canvas.
     */
    boolean expanded

}

/**
 * A directed connection from one activity (or pseudo-state) to another.
 * Corresponds to pd:transition in the process XML.
 *
 * The source and target are identified by the name of the containing
 * NamedElement (Activity, Starter, Group, or the special names "Start"
 * and "End" / "start" and "end" inside a group).
 */
class Transition {

    /**
     * Name of the source activity, group, or pseudo-state
     * (e.g. "Log", "Start", "IterateAndFindMatch").
     */
    String from
    
    refers Node source opposite outgoingTransitions

    /**
     * Name of the target activity, group, or pseudo-state
     * (e.g. "End", "MapResultToResponse").
     */
    String to
    
    refers Node target opposite incomingTransitions

    /**
     * Visual style of the transition line.
     * Common values: "Default", "Straight", "Curved".
     */
    String lineType

    /**
     * RGB color of the transition line encoded as a signed integer
     * (Java AWT convention), e.g. "-16777216" for black.
     */
    String lineColor

    /**
     * How the transition is enabled.
     * Common values: "always", "expression", "error", "timeout".
     */
    String conditionType

    /**
     * XPath/XSL condition expression evaluated at runtime to decide
     * whether this transition fires.  Only used when conditionType
     * is "expression".
     */
    String condition
}

/**
 * A visual annotation (sticky-note style label) placed on the design canvas.
 * Corresponds to pd:label in the process XML.
 */
class Label extends Node {

    /**
     * Width of the label box on the canvas.
     */
    int width

    /**
     * Height of the label box on the canvas.
     */
    int height

    /**
     * Font color encoded as an RGB integer string.
     */
    String fontColor

    /**
     * Background color encoded as an RGB integer string.
     */
    String color

    /**
     * Label shape type.
     */
    String ^type

    /**
     * Border line thickness.
     */
    String thickness

    /**
     * Opacity / fade value.
     */
    String fade
}

/**
 * A process-level variable declared in the processVariables section.
 * Process variables hold state that is visible to all activities within
 * the same process instance.
 */
class ProcessVariable extends TypedElement {

}

/**
 * Calls are used for resolving inter-process communications. 
 * 
 */
class Call {
    
    String description
    
    refers CallTarget target opposite incomingCalls
    
    container Caller caller opposite outgoingCalls
}

/**
 * Something that can receive calls
 */
interface CallTarget {
    
    refers Call[] incomingCalls opposite target
    
}

/**
 * Something making calls
 */
interface Caller {
    
    contains Call[] outgoingCalls opposite caller
    
}

// --- Project structure ---

/**
 * Project resource - process definition, XSD, ...
 */
class Resource {
    
    /**
     * Relative path in the project
     */
    String projectPath
    
    refers Folder parent opposite resources
    
}

class Folder extends Resource {
    
    refers Resource[] resources opposite parent  
    
    /**
     * Loaded from .folder file repository/folder resourceType attribute
     */
    String resourceType
    
    /**
     * Loaded from .folder file repository/folder name attribute
     */
    String name
        
}

/**
 * Project is folder with vcrepo.dat file and with resourceType="ae.rootfolder" in the .folder file
 */
class Project extends Folder {
    
}

